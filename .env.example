# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=          # server-only, never expose to the client

# --- Claude API (Module 2 + 3: style analysis & generation) ---
ANTHROPIC_API_KEY=

# --- Google Gemini Images API (Module 3: optional AI image generation) ---
# Only needed if you use the "Generate an image too" checkbox on the
# Generate post / Schedules forms. Free — get a key at
# aistudio.google.com/apikey, no card required (Google's free tier is
# currently ~500 images/day; check current limits there, they're Google's
# to change). Uses gemini-2.5-flash-image; images are uploaded to a public
# Supabase Storage bucket ("generated-images", auto-created by migration
# 0005) so the Threads API can fetch them by URL when publishing.
GEMINI_API_KEY=

# --- Threads scraping (Module 1) ---
# lib/threads/scraper.ts uses a self-hosted Playwright (headless Chromium)
# scraper — no API keys needed. Requires the Docker-based Railway build
# (see /Dockerfile + railway.json) for Chromium's system dependencies.
#
# Optional: log the scraper into a real Threads account to see full post
# history instead of the ~3-4 post preview anonymous visitors get. Capture
# this locally with `node scripts/capture-threads-session.mjs` (run on your
# own machine, your own network — never here), then base64-encode the
# resulting threads-session-state.json and paste it below / into Railway's
# Variables. This is as sensitive as a password — never commit the raw
# file, and be aware using it from Railway's IP (different from wherever
# you logged in) can read as suspicious to Meta and get the account
# flagged/restricted. See README.md "Module 1" for the full walkthrough.
THREADS_SESSION_STATE_B64=

# --- Official Meta Threads API (Module 4: auto-posting) ---
# App-level credentials from your Meta Developer App (Threads use case) --
# see README "Module 4" for the full walkthrough. Per-user access tokens are
# obtained via the in-app OAuth flow (Settings -> Threads API) and stored in
# Supabase, not here -- these three are the only Module 4 env vars needed.
THREADS_APP_ID=
THREADS_APP_SECRET=
THREADS_REDIRECT_URI=                # e.g. https://your-app.up.railway.app/api/threads/oauth/callback
                                      # must exactly match a "valid OAuth redirect URI" in the Meta App Dashboard

# Shared secret protecting the internal /api/cron/run-schedules endpoint
# (called by this app's own server.js every minute -- see server.js).
# Set this to any random string; if left blank the endpoint runs unprotected.
CRON_SECRET=
