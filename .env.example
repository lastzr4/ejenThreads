# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=          # server-only, never expose to the client

# --- Claude API (Module 2 + 3: style analysis & generation) ---
ANTHROPIC_API_KEY=

# --- Threads scraping source (Module 1, RapidAPI) ---
# From your RapidAPI listing's "Test Endpoint" panel:
THREADS_SCRAPER_API_KEY=            # your RapidAPI key (X-RapidAPI-Key)
THREADS_SCRAPER_HOST=               # e.g. some-host.p.rapidapi.com (X-RapidAPI-Host)
THREADS_SCRAPER_BASE_URL=           # full "get user posts" endpoint URL for that listing

# --- Official Meta Threads API (Module 4: auto-posting) ---
# Created via the Meta Developer portal -> Threads use case.
THREADS_APP_ID=
THREADS_APP_SECRET=
THREADS_ACCESS_TOKEN=               # long-lived user access token
THREADS_USER_ID=                    # your Threads account's numeric user id
