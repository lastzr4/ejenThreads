# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=          # server-only, never expose to the client

# --- Claude API (Module 2 + 3: style analysis & generation) ---
ANTHROPIC_API_KEY=

# --- Threads scraping (Module 1) ---
# No env vars needed here anymore — lib/threads/scraper.ts uses a
# self-hosted Playwright (headless Chromium) scraper instead of a
# third-party RapidAPI listing (every one we tried was dead/unreachable).
# Requires the Docker-based Railway build (see /Dockerfile + railway.json)
# so Chromium's system dependencies are available in the deploy image.

# --- Official Meta Threads API (Module 4: auto-posting) ---
# Created via the Meta Developer portal -> Threads use case.
THREADS_APP_ID=
THREADS_APP_SECRET=
THREADS_ACCESS_TOKEN=               # long-lived user access token
THREADS_USER_ID=                    # your Threads account's numeric user id
