# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=          # server-only, never expose to the client

# --- Claude API (Module 2 + 3: style analysis & generation) ---
ANTHROPIC_API_KEY=

# --- Threads scraping (Module 1) ---
# lib/threads/scraper.ts uses a self-hosted Playwright (headless Chromium)
# scraper — no API keys needed. Requires the Docker-based Railway build
# (see /Dockerfile + railway.json) for Chromium's system dependencies.
#
# Optional: log the scraper into a real Threads account to see full post
# history instead of the ~3-4 post preview anonymous visitors get. Capture
# this locally with `node scripts/capture-threads-session.mjs` (run on your
# own machine, your own network — never here), then base64-encode the
# resulting threads-session-state.json and paste it below / into Railway's
# Variables. This is as sensitive as a password — never commit the raw
# file, and be aware using it from Railway's IP (different from wherever
# you logged in) can read as suspicious to Meta and get the account
# flagged/restricted. See README.md "Module 1" for the full walkthrough.
THREADS_SESSION_STATE_B64=

# --- Official Meta Threads API (Module 4: auto-posting) ---
# Created via the Meta Developer portal -> Threads use case.
THREADS_APP_ID=
THREADS_APP_SECRET=
THREADS_ACCESS_TOKEN=               # long-lived user access token
THREADS_USER_ID=                    # your Threads account's numeric user id
